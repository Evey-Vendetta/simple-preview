{
  "name": "simple-preview",
  "displayName": "Preview in Simple Browser",
  "description": "Right-click any HTML file to instantly preview it in VS Code's built-in Simple Browser. Zero config, no external browser, built-in static server.",
  "version": "1.0.0",
  "publisher": "evey-vendetta",
  "author": {
    "name": "Evey Vendetta"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Evey-Vendetta/simple-preview"
  },
  "bugs": {
    "url": "https://github.com/Evey-Vendetta/simple-preview/issues"
  },
  "homepage": "https://github.com/Evey-Vendetta/simple-preview#readme",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "keywords": ["html", "preview", "simple browser", "live preview", "static server"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simplePreview.open",
        "title": "Preview in Simple Browser"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "simplePreview.open",
          "when": "resourceExtname == .html || resourceExtname == .htm",
          "group": "navigation"
        }
      ]
    }
  }
}
